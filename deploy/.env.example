# soma-vault local stack config — copy to deploy/.env and fill in.
# Generate the master key once (DO NOT commit the real value):
#   docker run --rm ghcr.io/chaitugsk07/soma-vault soma keygen
SOMA_MASTER_KEK_HEX=

# Audit log keys — 64 hex characters each (32 bytes).
# Generate with: openssl rand -hex 32
SOMA_AUDIT_MASTER_SECRET=
SOMA_AUDIT_SIGNING_KEY=
